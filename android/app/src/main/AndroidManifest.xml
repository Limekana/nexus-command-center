<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      android:allowBackup="false" + fullBackupContent="false" — opting out of
      Android's auto-backup means the IndexedDB (which contains all finance,
      study, fitness, and task data) is NOT uploaded to the user's Google Drive
      backup quota. Critical since the DB is currently unencrypted at rest;
      letting backups out would create a second exfiltration path beyond the
      device itself.
      android:usesCleartextTraffic="false" — defense-in-depth, blocks any
      accidental http:// URL the WebView might be asked to load.
      android:dataExtractionRules — explicitly disable D2D transfer & cloud
      backup at the OS level for Android 12+ (the boolean attrs above only
      cover legacy backup paths).
    -->
    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:usesCleartextTraffic="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Health Connect privacy policy intent (required by Health Connect) -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>

            <!-- OAuth callback deep link (Supabase → Google → back into app) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.limecore.nexus" />
            </intent-filter>
        </activity>

        <!-- Alias activity used by Health Connect on Android < 14 to show permissions UI -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- Custom AlarmManager → NotificationManager bridge. Receives the
             broadcast intent fired by AlarmManager at scheduled times and
             posts the actual notification. Not exported (only our own app
             can dispatch the alarm). -->
        <receiver
            android:name=".NotificationAlarmReceiver"
            android:exported="false" />
    </application>

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Android 13 (API 33) and above require an explicit runtime permission
         before any app can post notifications. Below 33 this is implicit, so
         the permission element is just a no-op. We need it for: weekly review
         reminders, task due-date pings, budget threshold alerts, portfolio
         end-of-day recaps, and news-driven alerts. All scheduled via our
         own custom NexusNotifications plugin (AlarmManager + NotificationManager)
         — no FCM, no GMS, so this stays F-Droid-clean. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- AlarmManager.setAndAllowWhileIdle needs WAKE_LOCK to wake the device
         from Doze when an alarm fires (e.g. the 4:05pm portfolio recap). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- RECEIVE_BOOT_COMPLETED would let us re-arm pending alarms after a
         device reboot. We intentionally DON'T request it for v1.0.x — the
         app does a full reconcile at next launch anyway, and avoiding this
         permission keeps the privacy profile cleaner. Future: add if users
         need notifications across reboots without opening the app. -->


    <!-- Health Connect: read-only access to Steps and Weight -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />

    <!-- Health Connect package query (Android 11+ requires explicit queries) -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>
</manifest>
